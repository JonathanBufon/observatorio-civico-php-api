{
  "info": {
    "name": "Observatorio Civico API",
    "description": "Colecao da API REST Laravel do Observatorio Civico.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('has data', function () { pm.expect(pm.response.json()).to.have.property('data'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Sources",
      "item": [
        {
          "name": "GET Sources",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sources?active=true&per_page=10"
          }
        },
        {
          "name": "GET Source",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sources/1"
          }
        },
        {
          "name": "GET Source Articles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sources/1/articles?has_analysis=false&per_page=10"
          }
        }
      ]
    },
    {
      "name": "Articles",
      "item": [
        {
          "name": "GET Articles",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/articles?per_page=10"
          }
        },
        {
          "name": "GET Articles Search",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/articles?q=congresso&has_analysis=true&per_page=10"
          }
        },
        {
          "name": "GET Article",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/articles/1"
          }
        },
        {
          "name": "GET Article Analysis",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/articles/1/analysis"
          }
        }
      ]
    },
    {
      "name": "Analyses",
      "item": [
        {
          "name": "GET Analyses",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analyses?per_page=10"
          }
        },
        {
          "name": "GET Analysis",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analyses/1"
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "GET Events",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/events?per_page=10"
          }
        },
        {
          "name": "GET Event",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/events/1"
          }
        },
        {
          "name": "GET Event Comparison",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/events/1/comparison"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1"
    }
  ]
}
